{
  "name": "ai-video-editor-desktop",
  "version": "0.1.0",
  "description": "AI视频自动剪辑桌面应用",
  "main": "main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "pack": "electron-packager . \"AI视频编辑器\" --platform=win32 --arch=x64 --out=release --overwrite --asar=false",
    "dist": "npm run build && npm run pack"
  },
  "author": "AI Video Editor Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-packager": "^17.1.2",
    "typescript": "^5.7.3"
  }
}
