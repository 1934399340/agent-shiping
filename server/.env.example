# AI视频剪辑器 - 环境变量配置
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# 视频素材搜索 API Key
# ============================================

# Pexels API Key (可选)
# 申请地址: https://www.pexels.com/api/
PEXELS_API_KEY=

# Pixabay API Key (可选)
# 申请地址: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ============================================
# 阿里云 TTS 配置 (可选)
# ============================================

# 阿里云 Access Key ID
ALIYUN_ACCESS_KEY_ID=

# 阿里云 Access Key Secret
ALIYUN_ACCESS_KEY_SECRET=

# 阿里云 TTS App Key
ALIYUN_TTS_APP_KEY=

# ============================================
# 服务器配置
# ============================================

# 服务端口 (默认 3001)
PORT=3001
